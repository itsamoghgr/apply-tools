# Copy this file to .env and fill in your real keys.

# ── Provider selection ──────────────────────────────────────────────────────
# AI_PROVIDER controls which backend is used for ALL generation calls
# (cover letters, emails, outreach, scoring, JD extraction).
# Options: "anthropic" (default), "groq", "nvidia"
# AI_PROVIDER=nvidia

# SCORE_PROVIDER overrides just the scoring path (defaults to AI_PROVIDER).
# SCORE_PROVIDER=groq

# ── Anthropic (Claude) ──────────────────────────────────────────────────────
# Required when AI_PROVIDER=anthropic (the default).
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default Claude model
# MODEL=claude-opus-4-5

# ── Groq ────────────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=groq, or when SCORE_PROVIDER=groq.
# Get one at: https://console.groq.com (free tier is fine)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default Groq model for generation tasks
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: override the Groq model used specifically for scoring
# SCORE_GROQ_MODEL=llama-3.3-70b-versatile

# ── NVIDIA NIM ──────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=nvidia.
# Get one at: https://build.nvidia.com (free tier available)
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default NIM model
# NIM_MODEL=meta/llama-3.3-70b-instruct

# ── Email tracking (Reach Out) ──────────────────────────────────────────────
# REQUIRED for the Reach Out feature. Mail clients can't reach localhost,
# so open/click tracking runs on a tiny FastAPI sidecar deployed on Render
# (see tracking-sidecar/README.md for one-time deploy instructions).
#
# All three vars are required; without them /reach-out/{id}/send returns a
# 400 instead of sending untracked email.

# The sidecar's public origin (no trailing slash). Render gives you a URL
# like https://apply-tools-tracker.onrender.com after the first deploy.
TRACKING_BASE_URL=https://apply-tools-tracker.onrender.com

# Base64 Fernet key. MUST match the value set on the sidecar — emails are
# encoded here and decoded there. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TRACKING_FERNET_KEY=replace-with-a-real-fernet-key

# Bearer token used by this backend when proxying /reach-out/{id}/events
# and /reach-out/aggregates to the sidecar. Any random string; must match
# the sidecar. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TRACKING_API_TOKEN=replace-with-a-real-random-token
