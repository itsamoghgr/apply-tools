# Copy this file to .env and fill in your real keys.

# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string. Must match the frontend's frontend/.env so the
# FastAPI backend (SQLAlchemy) and Next.js (Prisma) hit the same database.
# Local default created by the dev setup (see dev.md):
DATABASE_URL=postgresql://apply:apply@localhost:5432/apply_tools

# ── Provider selection ──────────────────────────────────────────────────────
# AI_PROVIDER controls which backend is used for ALL generation calls
# (cover letters, emails, outreach, scoring, JD extraction).
# Options: "anthropic" (default), "groq", "nvidia", "bedrock"
# AI_PROVIDER=nvidia

# SCORE_PROVIDER overrides just the scoring path (defaults to AI_PROVIDER).
# SCORE_PROVIDER=groq

# EXTRACT_PROVIDER overrides just the JD auto-detect path. Defaults to Groq
# (fast Llama), then falls back NVIDIA -> Bedrock -> Anthropic.
# EXTRACT_PROVIDER=groq

# ── Recommended setup: Bedrock Claude Sonnet for generation, Groq for extract ─
# AI_PROVIDER=bedrock          # cover / email / question / score -> Claude Sonnet 4.5
# EXTRACT_PROVIDER=groq        # auto-detect -> fast Groq Llama, falls back NVIDIA -> Bedrock (needs GROQ_API_KEY)

# On a recoverable failure (rate-limit / quota / timeout) the primary provider
# falls back down this chain until one succeeds: groq -> nvidia -> bedrock ->
# anthropic. Configure the keys for whichever providers you want in the chain;
# an unconfigured provider is simply skipped. Anthropic is the reliable
# backstop, so keeping ANTHROPIC_API_KEY set is recommended even off-default.

# ── Anthropic (Claude) ──────────────────────────────────────────────────────
# Required when AI_PROVIDER=anthropic (the default).
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default Claude model
# MODEL=claude-opus-4-5

# ── Groq ────────────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=groq, or when SCORE_PROVIDER=groq.
# Get one at: https://console.groq.com (free tier is fine)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default Groq model for generation tasks
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: override the Groq model used specifically for scoring
# SCORE_GROQ_MODEL=llama-3.3-70b-versatile

# ── NVIDIA NIM ──────────────────────────────────────────────────────────────
# Required when AI_PROVIDER=nvidia.
# Get one at: https://build.nvidia.com (free tier available)
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the default NIM model
# NIM_MODEL=meta/llama-3.3-70b-instruct

# ── AWS Bedrock ─────────────────────────────────────────────────────────────
# Used when AI_PROVIDER=bedrock, or as a fallback in the chain above.
# Auth uses the standard AWS credential chain: set AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY here, or rely on ~/.aws/credentials or an IAM role.
# The IAM principal needs bedrock:InvokeModel on the models below, and the
# models must be enabled in your account's Bedrock console for the region.
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Region for Bedrock. Falls back to AWS_REGION, then us-east-1.
# BEDROCK_REGION=us-east-1

# Generation / score / answer use Claude Sonnet 4.5 on Bedrock by default.
# Sonnet 4.5 requires a region-prefixed inference profile (us.* / global.*);
# the bare anthropic.claude-sonnet-4-5-... id raises a ValidationException.
# BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Auto-detect (JD extraction) uses Llama 3.3 70B on Bedrock by default,
# matching the lighter model used on the groq/nvidia extract path.
# BEDROCK_EXTRACT_MODEL=meta.llama3-3-70b-instruct-v1:0

# ── Email tracking (Reach Out) ──────────────────────────────────────────────
# REQUIRED for the Reach Out feature. Mail clients can't reach localhost,
# so open/click tracking runs on a tiny FastAPI sidecar deployed on Render
# (see tracking-sidecar/README.md for one-time deploy instructions).
#
# All three vars are required; without them /reach-out/{id}/send returns a
# 400 instead of sending untracked email.

# The sidecar's public origin (no trailing slash). Render gives you a URL
# like https://apply-tools-tracker.onrender.com after the first deploy.
TRACKING_BASE_URL=https://apply-tools-tracker.onrender.com

# Base64 Fernet key. MUST match the value set on the sidecar — emails are
# encoded here and decoded there. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TRACKING_FERNET_KEY=replace-with-a-real-fernet-key

# Bearer token used by this backend when proxying /reach-out/{id}/events
# and /reach-out/aggregates to the sidecar. Any random string; must match
# the sidecar. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TRACKING_API_TOKEN=replace-with-a-real-random-token
