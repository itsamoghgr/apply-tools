generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id              String           @id
  label           String
  content         String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  applications    Application[]
  jobApplications JobApplication[]
  reachOuts       ReachOut[]
  // When set, this row is a synced companion of a resume-builder profile.
  // The builder is the source of truth; saving the profile upserts this row,
  // and deleting the profile cascades to remove it. Hand-written resumes leave
  // this null. See resume-builder/actions.ts (syncCompanionResume).
  resumeProfileId String?          @unique
  resumeProfile   ResumeProfile?   @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
}

model Application {
  id             String   @id
  mode           String
  company        String?
  jobDescription String?
  resumeId       String?
  resume         Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  output         String?
  scoreData     String?
  pdfPath        String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([mode])
}

model JobApplication {
  id                String    @id
  companyName       String
  jobRole           String?
  jobUrl            String?
  location          String?
  interviewStatus   String?
  status            String    @default("Applied")
  appliedDate       DateTime  @default(now())
  resumeId          String?
  resume            Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  companyCareerPage String?
  decisionDate      DateTime?
  decisionTime      String?
  notes             String?
  hrName            String?
  hrLinkedin        String?
  hrEmail           String?
  referral          String?
  referralLinkedin  String?
  jobDescription    String?
  // One editable cover letter per tracked job. `coverLetter` is the letter body
  // (plain text, whitelisted \emph/\textbf kept for the PDF render). `coverLetterMeta`
  // captures {roleTitle, hiringManager, resumeId} from generation so the on-demand
  // PDF re-renders consistently. Both null until a letter is generated/saved.
  coverLetter       String?
  coverLetterMeta   Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leads             JobApplicationLead[]
  reachOuts         ReachOut[]

  @@index([createdAt])
  @@index([status])
}

model JobApplicationLead {
  jobApplicationId String
  leadId           String
  role             String?
  createdAt        DateTime       @default(now())
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([jobApplicationId, leadId])
  @@index([leadId])
}

model ReachOut {
  id              String    @id
  recipientName   String
  recipientEmail  String
  linkedinProfile String
  contextNote     String?
  resumeId        String?
  resume          Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  channel         String    @default("email")
  subject         String
  body            String
  htmlBody        String?
  status          String    @default("draft")
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  jobApplicationId String?
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@index([leadId])
  @@index([jobApplicationId])
}

model Lead {
  id              String     @id
  name            String
  email           String?    @unique
  linkedinUrl     String?
  linkedinProfile String?
  currentCompany  String?
  role            String?
  replied         Boolean    @default(false)
  repliedAt       DateTime?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  reachOuts       ReachOut[]
  applications    JobApplicationLead[]

  // Company-lead fields populated by the lead-generation agent service
  // (agent_server/, port 8001). Added via agent_server/db/platform_migration.sql;
  // mirrored here so Prisma stays in sync. `domain` carries a DB-level partial
  // UNIQUE index (WHERE domain IS NOT NULL) that Prisma can't express, so it is
  // a plain indexed column here — the upsert dedup is enforced by that index.
  domain          String?
  companyName     String?
  fundingStage    String?
  fundingAmount   String?
  founderName     String?
  employeeCount   String?
  revenue         String?
  location        String?
  industry        String?
  lastRoundDate   String?
  confidence      Float?
  source          String?
  sourcesJson     Json?

  // Deep-research fields populated by the lead-generation agent service.
  // Added OUT-OF-BAND via agent_server/db/deep_research_migration.sql; mirrored
  // here so Prisma stays in sync (NOT applied via prisma migrate).
  brief           String?
  foundingYear    String?
  totalRaised     String?
  investorsJson   Json?
  competitorsJson Json?
  keyPeopleJson   Json?
  fitScore        Float?
  fitReason       String?

  @@index([createdAt])
  @@index([replied])
  // NOTE: `domain` already has a DB-level partial UNIQUE index from
  // agent_server/db/platform_migration.sql (WHERE domain IS NOT NULL); we don't
  // redeclare it here to avoid Prisma drift against that out-of-band index.
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Structured resume authored in the Resume Builder. Sections are stored as
// JSON so the builder can evolve fields without a migration each time; the
// backend (resume_render.py) renders this shape to the sb2nov LaTeX template.
//   header     -> { fullName, phone, email, linkedin, github, portfolio, scholar, location }
//   education  -> [{ school, dates, degree, location }]
//   experience -> [{ company, dates, title, location, bullets: string[] }]
//   skills     -> [{ category, items }]
//   projects   -> [{ name, date, bullets: string[] }]
model ResumeProfile {
  id         String   @id
  name       String
  header     Json     @default("{}")
  education  Json     @default("[]")
  experience Json     @default("[]")
  skills     Json     @default("[]")
  projects   Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  // Companion plaintext Resume synced from this profile so it can be selected
  // in the applications / reach-out / AI pickers. Cascade-deletes with this row.
  resume     Resume?

  @@index([updatedAt])
}

// ── Master Profile ────────────────────────────────────────────────────────────
// A singleton-ish record (id = "me") that stores the user's canonical work
// history. Separate from ResumeProfile, which is a per-document builder draft.
model Profile {
  id          String       @id
  fullName    String?
  email       String?
  phone       String?
  location    String?
  linkedin    String?
  github      String?
  portfolio   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  experiences Experience[]
  projects    Project[]
  skills      Skill[]
}

model Experience {
  id        String   @id
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company   String
  title     String
  location  String?
  startDate String?
  endDate   String?
  bullets   String[] @default([])
  order     Int      @default(0)

  @@index([profileId, order])
}

model Project {
  id        String   @id
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  date      String?
  link      String?
  bullets   String[] @default([])
  order     Int      @default(0)

  @@index([profileId, order])
}

model Skill {
  id        String   @id
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  category  String
  items     String[] @default([])
  order     Int      @default(0)

  @@index([profileId, order])
}
