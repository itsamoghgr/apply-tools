generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id              String           @id
  label           String
  content         String
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  applications    Application[]
  jobApplications JobApplication[]
  reachOuts       ReachOut[]
}

model Application {
  id             String   @id
  mode           String
  company        String?
  jobDescription String?
  resumeId       String?
  resume         Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  output         String?
  scoreData     String?
  pdfPath        String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
  @@index([mode])
}

model JobApplication {
  id                String    @id
  companyName       String
  jobRole           String?
  jobUrl            String?
  location          String?
  interviewStatus   String?
  status            String    @default("Applied")
  appliedDate       DateTime  @default(now())
  resumeId          String?
  resume            Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  companyCareerPage String?
  decisionDate      DateTime?
  decisionTime      String?
  notes             String?
  hrName            String?
  hrLinkedin        String?
  hrEmail           String?
  referral          String?
  referralLinkedin  String?
  jobDescription    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  leads             JobApplicationLead[]
  reachOuts         ReachOut[]

  @@index([createdAt])
  @@index([status])
}

model JobApplicationLead {
  jobApplicationId String
  leadId           String
  role             String?
  createdAt        DateTime       @default(now())
  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
  lead             Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([jobApplicationId, leadId])
  @@index([leadId])
}

model ReachOut {
  id              String    @id
  recipientName   String
  recipientEmail  String
  linkedinProfile String
  contextNote     String?
  resumeId        String?
  resume          Resume?   @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  channel         String    @default("email")
  subject         String
  body            String
  htmlBody        String?
  status          String    @default("draft")
  sentAt          DateTime?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  jobApplicationId String?
  jobApplication   JobApplication? @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@index([leadId])
  @@index([jobApplicationId])
}

model Lead {
  id              String     @id
  name            String
  email           String?    @unique
  linkedinUrl     String?
  linkedinProfile String?
  currentCompany  String?
  role            String?
  replied         Boolean    @default(false)
  repliedAt       DateTime?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  reachOuts       ReachOut[]
  applications    JobApplicationLead[]

  @@index([createdAt])
  @@index([replied])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Structured resume authored in the Resume Builder. Sections are stored as
// JSON so the builder can evolve fields without a migration each time; the
// backend (resume_render.py) renders this shape to the sb2nov LaTeX template.
//   header     -> { fullName, phone, email, linkedin, github, portfolio, scholar, location }
//   education  -> [{ school, dates, degree, location }]
//   experience -> [{ company, dates, title, location, bullets: string[] }]
//   skills     -> [{ category, items }]
//   projects   -> [{ name, date, bullets: string[] }]
model ResumeProfile {
  id         String   @id
  name       String
  header     Json     @default("{}")
  education  Json     @default("[]")
  experience Json     @default("[]")
  skills     Json     @default("[]")
  projects   Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([updatedAt])
}
