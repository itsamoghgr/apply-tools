# ── Agent server ────────────────────────────────────────────────────────────
AGENT_HOST=0.0.0.0
AGENT_PORT=8002

# Agent DB — operational store ONLY (jobs, checkpoints, seen-cache, outbox,
# audit). SEPARATE Postgres database from the platform's apply_tools DB.
AGENT_DATABASE_URL=postgresql://apply:apply@localhost:5432/apply_agent

# Platform API — source of truth for verified leads. The agent server is a CLIENT.
PLATFORM_API_BASE=http://localhost:8001
# PLATFORM_API_TOKEN=shared-secret   # optional; sent as X-Agent-Token

# ── Run shape ───────────────────────────────────────────────────────────────
HUNT_TARGET_COUNT=50
LOOP_SLEEP_MIN_S=0.5
LOOP_SLEEP_MAX_S=2.0

# ── Runtime LLM agents (discovery + research) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
AGENT_LLM_MODEL=claude-opus-4-8

# ── Structured-floor discovery sources ──────────────────────────────────────
YC_OSS_URL=https://yc-oss.github.io/api/companies/all.json
# PRODUCT_HUNT_TOKEN=xxxx   # Product Hunt developer token (free)

# ── Verification waterfall (free-tier APIs in order, then SMTP fallback) ─────
VERIFY_PROVIDERS=hunter,abstract
# HUNTER_API_KEY=xxxx
# ABSTRACT_API_KEY=xxxx
SMTP_FALLBACK_ENABLED=true

# ── Logging (shared with platform conventions) ──────────────────────────────
LOG_FORMAT=console     # or "json"
LOG_LEVEL=INFO
ENV=development
